# =====================================================================
# Server-side (Vercel project env vars) — used by api/recommend.js and
# api/generate-image.js. THESE NEVER REACH THE BROWSER.
# Set them in the Vercel dashboard: Settings → Environment Variables.
# =====================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides on the server
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# =====================================================================
# Client-side (Vite) — only needed for local development without
# `vercel dev`. These get bundled into the JS — DO NOT use in production.
# =====================================================================
# VITE_GEMINI_API_KEY=your_dev_only_key
# VITE_GEMINI_TEXT_MODEL=gemini-2.5-flash
# VITE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview
