# ---- Supabase ----
# Project URL + keys from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only — NEVER expose to the client

# ---- Marketing / lifecycle ----
LIFECYCLE_WEBHOOK_URL=            # optional: Resend/Postmark/Zapier inbound webhook

# ---- Email provider webhooks ----
EMAIL_WEBHOOK_SECRET=            # HMAC secret used to verify bounce/open/click callbacks

# ---- Protected internal endpoints ----
CRON_SECRET=                    # protects /api/cron/lifecycle (Vercel sends it as Bearer token)
ADMIN_API_KEY=                  # protects /api/admin/leads/export and admin deletes

# ---- Sending (Phase T — Resend) ----
# Required for the hourly lifecycle cron to actually send. Without these the
# cron returns 503 — the schedule does NOT advance, so leads are not skipped.
RESEND_API_KEY=                 # Resend API key (Resend dashboard → API Keys)
FROM_EMAIL=Taper Empire <brief@taperempire.com>
# Optional — base URL used in template unsubscribe links + brand CTA:
NEXT_PUBLIC_SITE_URL=https://tool.taperempire.com
# Domain must have DKIM + SPF + DMARC verified at Resend before sending.
# See docs/SUPABASE_SETUP.md "Provider wiring (Phase 7/8 follow-up)".
